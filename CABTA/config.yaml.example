api_keys:
  virustotal: ''
  abuseipdb: ''
  shodan: ''
  alienvault: ''
  hybrid_analysis: ''
  greynoise: ''
  urlscan: ''
  openrouter: ''
  gemini: ''
llm:
  provider: router
  base_url: http://localhost:20128/v1
  model: gpt-5.4
  timeout_seconds: 120
agent:
  max_steps: 1000
  auto_enrich_timeout_seconds: 12
  chat_tool_cap: 14
  chat_prompt_findings_limit: 5
  chat_auto_enrich_limit: 1
  chat_response_timeout_seconds: 120
  llm_request_interpreter:
    mode: primary
    max_repair_attempts: 1
    min_accept_confidence: 0.75
    min_clarify_confidence: 0.5
    audit_deterministic_diff: true
    safety_gates_enforced:
      schema_validation: true
      parameter_binding: true
      preflight_validation: true
      destructive_action_approval: true
      final_answer_evidence_gate: true
      deterministic_verdict_authority: true
  autonomy:
    level: assistive
  context:
    enabled: true
    context_window_tokens: 32000
    reserved_output_tokens: 4096
    safety_margin_tokens: 1024
    hard_prompt_budget_ratio: 0.92
    compaction_threshold_ratio: 0.85
    max_context_pack_bytes: 200000
    max_ledger_items: 120
    section_budgets:
      system_rules: 0.1
      goal: 0.06
      reasoning: 0.2
      evidence: 0.24
      entities: 0.1
      hypotheses: 0.12
      coverage: 0.08
      tools: 0.06
      workflow: 0.04
  runtime_mode: production
  execution:
    strict_dag_max_retries: 0
  tool_policy:
    allowed_scopes:
    - data:logs
    - network:siem
    - network:external
    - file:read
    - sandbox:submit
analysis:
  max_file_size_mb: 100
  timeout_seconds: 300
  enable_sandbox: true
  enable_yara: true
  llm_timeout_seconds: 25
  text_max_scan_mb: 3
output:
  default_format: cli
  save_reports: true
  report_dir: ./reports
logging:
  level: INFO
  file: ''
web:
  demo_mode:
    enabled: false
    dataset: default
log_hunting:
  max_window_hours: 168
  max_results: 200
  max_queries_per_hunt: 3
  max_retry_attempts: 3
  max_attempts_per_gap: 2
  max_attempts_per_objective: 3
  max_attempts_per_session: 6
  llm_query_assist_enabled: false
  llm_query_assist_max_candidates: 3
  llm_query_assist_require_validation: true
daemon:
  enabled: false
  retry_backoff_seconds: 60
  lease_timeout_seconds: 300
  schedules: []
mcp_servers:
- name: free-osint
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.free_osint_tools
  description: Free OSINT enrichment and phishing / malware feed lookups
  auto_connect: true
- name: osint-tools
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.osint_tools
  description: WHOIS, DNS, SSL, domain age, and lightweight OSINT utilities
  auto_connect: true
- name: threat-intel-free
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.threat_intel_tools
  env:
    ABUSECH_AUTH_KEY: ''
  description: Free threat intel feeds for IP, domain, URL, and hash pivoting
  auto_connect: true
- name: vulnerability-tools
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.vulnerability_tools
  description: CVE, KEV, EPSS, and vulnerability context helpers
  auto_connect: true
- name: network-analysis
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.network_tools
  description: Network and protocol analysis helpers
  auto_connect: true
- name: forensics-tools
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.forensics_tools
  description: Local forensics and evidence extraction helpers
  auto_connect: true
- name: malwoverview
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.malwoverview_tools
  env:
    ABUSECH_AUTH_KEY: ''
  description: Malware triage helpers and static overview tooling
  auto_connect: true
- name: remnux
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.remnux_tools
  description: REMnux-style malware analysis helpers
  auto_connect: true
- name: ghidra
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.ghidra_tools
  description: Reverse engineering helpers with optional Ghidra integration
  auto_connect: true
- name: mobsf
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.mobsf_tools
  description: Mobile app analysis helpers with optional MobSF integration
  auto_connect: true
- name: flare
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.flare_tools
  description: FLARE-style reverse engineering helpers
  auto_connect: true
- name: splunk
  transport: stdio
  command: .\.venv\Scripts\python.exe
  args:
  - -m
  - src.mcp_servers.splunk_tools
  env:
    SPLUNK_URL: https://splunk.example.local:8089
    SPLUNK_TOKEN: ''
    SPLUNK_VERIFY_TLS: 'true'
    SPLUNK_ALLOWED_INDEXES: main,soc101
    SPLUNK_MAX_WINDOW_HOURS: '168'
    SPLUNK_MAX_RESULTS: '200'
  description: Read-only Splunk hunting, pivots, and host timeline lookups
  auto_connect: false
runtime:
  mode: production
  supervisor:
    enabled: true
    max_queue_size: 100
    worker_count: 1
