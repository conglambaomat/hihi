# CABTA Configuration
# Copy this file to config.yaml and add your API keys

# API Keys (Optional - tool works without them but with limited features)
api_keys:
  virustotal: ""          # https://www.virustotal.com/gui/my-apikey
  abuseipdb: ""           # https://www.abuseipdb.com/account/api
  shodan: ""              # https://account.shodan.io/
  alienvault: ""          # https://otx.alienvault.com/api
  hybrid_analysis: ""     # https://www.hybrid-analysis.com/my-account?tab=api-key
  greynoise: ""           # https://viz.greynoise.io/account/api-key
  urlscan: ""             # https://urlscan.io/user/profile/
  groq: ""                # https://console.groq.com/keys

# LLM Configuration (Optional - for AI-powered analysis)
llm:
  provider: "ollama"      # Options: ollama, groq, anthropic
  ollama_model: "llama3.1:8b"
  ollama_endpoint: "http://localhost:11434"
  groq_model: "openai/gpt-oss-20b"
  groq_endpoint: "https://api.groq.com/openai/v1"
  anthropic_model: "claude-sonnet-4-20250514"

# Analysis Settings
analysis:
  max_file_size_mb: 100   # Maximum file size for analysis
  timeout_seconds: 300    # Analysis timeout
  enable_sandbox: true    # Enable sandbox integration
  enable_yara: true       # Enable YARA scanning

# Output Settings
output:
  default_format: "cli"   # Options: cli, json, html
  save_reports: true      # Auto-save HTML reports
  report_dir: "./reports" # Report output directory

# Logging
logging:
  level: "INFO"           # Options: DEBUG, INFO, WARNING, ERROR
  file: ""                # Log file path (empty = console only)

# Web Dashboard
web:
  demo_mode:
    enabled: false        # Use deterministic demo fixtures for localhost walkthroughs
    dataset: "default"    # Fixture set under data/demo/

# Log hunting defaults
log_hunting:
  max_window_hours: 168
  max_results: 200
  max_queries_per_hunt: 3
  demo_backend:
    enabled: false        # Use the seeded playbook log fixture when Splunk is unavailable
    dataset: "playbook_log_hunt"

# Optional headless SOC daemon
daemon:
  enabled: false
  retry_backoff_seconds: 60
  lease_timeout_seconds: 300
  schedules: []

# Built-in MCP Servers
# These names intentionally match the playbook references under data/playbooks/.
# Start CABTA from the project root so relative paths resolve correctly.
mcp_servers:
  - name: "free-osint"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.free_osint_tools"]
    description: "Free OSINT enrichment and phishing / malware feed lookups"
    auto_connect: true

  - name: "osint-tools"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.osint_tools"]
    description: "WHOIS, DNS, SSL, domain age, and lightweight OSINT utilities"
    auto_connect: true

  - name: "threat-intel-free"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.threat_intel_tools"]
    env:
      ABUSECH_AUTH_KEY: ""
    description: "Free threat intel feeds for IP, domain, URL, and hash pivoting"
    auto_connect: true

  - name: "vulnerability-tools"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.vulnerability_tools"]
    description: "CVE, KEV, EPSS, and vulnerability context helpers"
    auto_connect: true

  - name: "network-analysis"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.network_tools"]
    description: "Network and protocol analysis helpers"
    auto_connect: true

  - name: "forensics-tools"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.forensics_tools"]
    description: "Local forensics and evidence extraction helpers"
    auto_connect: true

  - name: "malwoverview"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.malwoverview_tools"]
    env:
      ABUSECH_AUTH_KEY: ""
    description: "Malware triage helpers and static overview tooling"
    auto_connect: true

  - name: "remnux"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.remnux_tools"]
    description: "REMnux-style malware analysis helpers"
    auto_connect: true

  - name: "ghidra"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.ghidra_tools"]
    description: "Reverse engineering helpers with optional Ghidra integration"
    auto_connect: true

  - name: "mobsf"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.mobsf_tools"]
    description: "Mobile app analysis helpers with optional MobSF integration"
    auto_connect: true

  - name: "flare"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.flare_tools"]
    description: "FLARE-style reverse engineering helpers"
    auto_connect: true

  - name: "splunk"
    transport: "stdio"
    command: ".\\.venv\\Scripts\\python.exe"
    args: ["-m", "src.mcp_servers.splunk_tools"]
    env:
      SPLUNK_URL: "https://splunk.example.local:8089"
      SPLUNK_TOKEN: ""
      SPLUNK_VERIFY_TLS: "true"
      SPLUNK_ALLOWED_INDEXES: "main,endpoint,network"
      SPLUNK_MAX_WINDOW_HOURS: "168"
      SPLUNK_MAX_RESULTS: "200"
    description: "Read-only Splunk hunting, pivots, and host timeline lookups"
    auto_connect: false
